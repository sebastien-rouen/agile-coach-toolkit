# 🌍 ENVIRONNEMENT
NODE_ENV=development
DEPLOY_ENV=staging

# 📁 CHEMINS DÉPLOIEMENT
STAGING_PATH=/sites/drafts/agile-coach-toolkit
PROD_PATH=/sites/prod/agile-coach-toolkit
BACKUP_PATH=/sites/backups/agile-coach-toolkit

# 🌐 DOMAINES
STAGING_DOMAIN=agile-dev.site.fr
PROD_DOMAIN=agile.site.fr

# 📊 ANALYTICS
LOG_PATH=/var/log/nginx/agile-coach-toolkit-access.log
STATS_PATH=/sites/data/agile-coach-toolkit-stats
STATS_PORT=3001

# 🔐 SÉCURITÉ
ADMIN_TOKEN=your-secret-token-here
ALLOWED_IPS=192.168.1.0/24,127.0.0.1

# 📧 NOTIFICATIONS (optionnel)
NOTIFY_EMAIL=admin@mail.fr

# 🛠️ DEV
DEV_PORT=3000
LIVE_RELOAD=true
