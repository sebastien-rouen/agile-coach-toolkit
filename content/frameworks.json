    {
      "id": "kanban-method",
      "title": "🎢 Kanban Method",
      "description": "Méthode de flux continu pour optimiser le travail en cours",
      "tags": ["kanban", "flux", "wip", "continu"],
      "icon": "fas fa-columns",
      "content": "Système visuel de gestion du flux de travail basé sur la limitation du WIP",
      "sections_detaillees": {
        "pitch_elevator": "Kanban, c'est comme la file d'attente chez le boulanger : tu vois ce qui arrive, ce qui se prépare, ce qui est prêt. Pas de course, pas de stress, juste un flux régulier et visible !",
        "analogies_choix": {
            "cuisine": "C'est comme choisir son style de cuisine : Scrum = cuisine de chef (créativité + technique), Kanban = cuisine de bistrot (efficace + adaptatif), Waterfall = cuisine industrielle (process + volume), Scrumban = cuisine fusion (mélange des styles)",
            "sport": "Comme choisir son sport d'équipe : Scrum = rugby (stratégie + cohésion), Kanban = course relais (flux + handoff), Waterfall = natation synchronisée (chorégraphie + précision), Scrumban = triathlon (polyvalence + endurance)"
        },
        "citations": [
          {
            "texte": "Arrêtez de commencer, commencez à finir",
            "auteur": "David J. Anderson",
            "source": "Kanban Method"
          }
        ],
        "calendrier": {
          "duree": "Flux continu sans itérations fixes",
          "etapes": ["Visualiser", "Limiter WIP", "Gérer flux", "Améliorer"]
        },
        "tableau_comparaison": {
          "criteres": ["Structure", "Planification", "Changements", "Mesures"],
          "options": [
            {"nom": "Kanban", "structure": "Flexible", "planification": "Continue", "changements": "Immédiate", "mesures": "Lead Time"}
          ]
        },
        "templates": [
          {
            "nom": "Kanban Board Template",
            "description": "Tableau basique : To Do / Doing / Done",
            "format": "Template digital"
          }
        ],
        "checklist": [
          "Flux de travail identifié et cartographié",
          "Colonnes du tableau définies",
          "Limites WIP établies par colonne",
          "Règles explicites documentées",
          "Métriques de flux mises en place"
        ],
        "exemples_pratiques": [
          {
            "contexte": "Support client avec demandes variables",
            "solution": "Board : Nouveau / Analyse / En cours / Test / Résolu - WIP limité à 3 par personne",
            "resultat": "Temps de résolution réduit de 40%, moins de stress équipe"
          }
        ],
        "metriques": [
          {
            "nom": "Lead Time",
            "formule": "Temps total de prise en charge d'une demande",
            "cible": "Réduction progressive et stabilité"
          },
          {
            "nom": "Throughput",
            "formule": "Nombre d'éléments livrés par période",
            "cible": "Augmentation progressive"
          }
        ],
        "outils_recommandes": [
          {
            "nom": "Trello",
            "usage": "Kanban simple et visuel",
            "lien": "https://trello.com"
          }
        ],
        "anti_patterns": [
          {
            "probleme": "Pas de limite WIP",
            "consequence": "Tout est urgent, rien n'avance",
            "solution": "Limiter le travail en cours selon la capacité équipe"
          }
        ]
      }
    },
    {
