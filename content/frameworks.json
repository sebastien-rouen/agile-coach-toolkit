      "sections_detaillees": {
        "pitch_elevator": "Scrumban, c'est comme cuisiner avec une recette (Scrum) mais en s'adaptant selon les ingrédients du moment (Kanban). Le meilleur des deux mondes !",
        "citations": [
          {
            "texte": "Scrumban est né de la nécessité pratique, pas de la théorie",
            "auteur": "Corey Ladas",
            "source": "Scrumban Essays"
          }
        ],
        "calendrier": {
          "duree": "Sprints flexibles + flux continu",
