        "pitch_elevator": "Les anti-patterns, c'est comme les virus informatiques : mieux vaut les connaître pour les éviter plutôt que les subir !",
        "anti_patterns": [
          {
            "probleme": "Scrum Master = Chef de projet déguisé",
            "consequence": "Command & control, pas d'auto-organisation",
            "solution": "Formation posture servant-leader"
          },
          {
            "probleme": "Sprint = Mini-cascade",
            "consequence": "Pas de collaboration, silos maintenus",
            "solution": "Revoir définition Sprint, formation équipe"
          },
          {
            "probleme": "Vélocité = Productivité individuelle",
            "consequence": "Competition interne, qualité dégradée",
            "solution": "Focus valeur équipe, pas performance individuelle"
          }
        ]
      }
    },
