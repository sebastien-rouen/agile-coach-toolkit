    {
      "id": "sprint-review",
      "title": "📦 Sprint Review",
      "description": "Démonstration et feedback sur l'incrément produit",
      "tags": ["review", "demo", "feedback", "stakeholders"],
      "icon": "fas fa-presentation",
      "content": "Cérémonie de présentation du travail réalisé pendant le Sprint",
      "sections_detaillees": {
        "pitch_elevator": "La Sprint Review, c'est comme présenter tes plats aux invités : tu montres ce que tu as cuisiné, tu reçois les compliments ET les critiques pour améliorer le prochain repas !",
        "citations": [
          {
            "texte": "Le feedback est le petit-déjeuner des champions",
            "auteur": "Ken Blanchard",
            "source": "The One Minute Manager"
          }
        ],
        "calendrier": {
          "duree": "2h max pour Sprint de 2 semaines",
          "etapes": ["Demo du travail fini", "Feedback stakeholders", "Adaptation Product Backlog", "Discussion de la suite"]
        },
        "checklist": [
          "Incrément démontrable préparé",
          "Stakeholders invités et présents",
          "Product Owner anime la session",
          "Focus sur le FAIT, pas le travail en cours",
          "Feedback collecté et documenté",
          "Product Backlog mis à jour"
        ],
        "anti_patterns": [
          {
            "probleme": "Présentation PowerPoint au lieu de démo produit",
            "consequence": "Perte de confiance, feedback non pertinent",
            "solution": "Toujours démontrer le produit fonctionnel réel"
          }
        ]
      }
    },
