        "techniques": [
          {
            "nom": "MoSCoW",
            "description": "Must/Should/Could/Won't have",
            "usage": "Priorisation release"
          },
          {
            "nom": "Value vs Effort",
            "description": "Matrice impact/effort",
            "usage": "Identification quick wins"
          },
          {
            "nom": "Kano Model",
            "description": "Basic/Performance/Delight features",
            "usage": "Stratégie fonctionnalités"
          }
        ],
        "templates": [
          {
            "nom": "User Story Template",
            "description": "En tant que... Je veux... Afin de...",
            "format": "Template standardisé"
          }
        ]
      }
    },
    {
      "id": "product-roadmapping",
      "title": "🗺️ Product Roadmapping",
      "description": "Planification stratégique du produit",
      "tags": ["roadmap", "stratégie", "planification", "vision"],
      "icon": "fas fa-route",
      "content": "Construction et communication de la roadmap produit",
      "sections_detaillees": {
        "pitch_elevator": "La roadmap, c'est comme planifier des vacances : destination claire, étapes importantes, mais flexible sur les détails du voyage !",
        "calendrier": {
          "duree": "Vision 12-18 mois, détail 3-6 mois",
          "etapes": ["Vision produit", "Thèmes majeurs", "Releases", "Ajustements trimestriels"]
        },
        "anti_patterns": [
          {
            "probleme": "Roadmap = Gantt déguisé avec dates fixes",
            "consequence": "Rigidité, pas d'adaptation marché",
            "solution": "Roadmap par outcomes, pas par dates"
          }
        ]
      }
    },
    {
      "id": "design-thinking-process",
      "title": "🎨 Design Thinking Process",
      "description": "Processus créatif centré utilisateur",
      "tags": ["design-thinking", "créativité", "utilisateur", "innovation"],
      "icon": "fas fa-lightbulb",
      "content": "Méthodologie d'innovation centrée utilisateur",
      "sections_detaillees": {
        "pitch_elevator": "Design Thinking, c'est comme être cuisinier : goûter ce que mange le client (empathie), imaginer nouveau plat (idéation), tester recette (prototype) !",
        "calendrier": {
          "duree": "1-5 jours selon complexité",
          "etapes": ["Empathie", "Définition", "Idéation", "Prototypage", "Test"]
        },
        "templates": [
          {
            "nom": "Empathy Map",
            "description": "Ce que dit/fait/pense/ressent l'utilisateur",
            "format": "Canvas 4 quadrants"
          },
          {
            "nom": "How Might We",
            "description": "Reformulation problème en opportunité",
            "format": "Questions ouvertes"
          }
        ]
      }
    },
    {
      "id": "user-research-personas",
      "title": "👤 User Research & Personas",
      "description": "Recherche utilisateur et création de personas",
      "tags": ["user-research", "personas", "interviews", "insights"],
